# Copy this file to .env and fill in your keys
# NEVER commit .env to git

# Groq AI Keys (required) — get free keys at https://console.groq.com
GROQ_API_KEY_1=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_API_KEY_2=gsk_yyyyyyyyyyyyyyyyyyyyyyyyyyyy

# Resend Email API (optional) — https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# WhatsApp Business Cloud API (optional) — https://developers.facebook.com
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=1234567890123456

# Fallback recipients (used if no contacts in DB)
REPORT_EMAIL=news@yourdomain.com
REPORT_WHATSAPP=+919876543210
